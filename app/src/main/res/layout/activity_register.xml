<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Image/Logo de l'app -->
        <TextView
            android:text="🎨"
            android:textSize="80sp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Titre avec animation -->
        <TextView
            android:id="@+id/txtRegisterTitle"
            android:text="✨ Rejoins-nous ! ✨"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="#FF6B6B"
            android:layout_marginBottom="8dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:text="Crée ton compte pour commencer"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginBottom="32dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Card pour les inputs -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:orientation="vertical"
                android:padding="24dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Input Nom -->
                <TextView
                    android:text="👤 Ton nom"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F8F8F8"
                    android:layout_marginBottom="20dp">

                    <EditText
                        android:id="@+id/nameInput"
                        android:hint="Écris ton nom ici"
                        android:textColorHint="#9E9E9E"
                        android:textColor="#000000"
                        android:background="@android:color/transparent"
                        android:padding="16dp"
                        android:textSize="16sp"
                        android:inputType="textPersonName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </androidx.cardview.widget.CardView>

                <!-- Input Email -->
                <TextView
                    android:text="📧 Ton email"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F8F8F8"
                    android:layout_marginBottom="20dp">

                    <EditText
                        android:id="@+id/registerEmail"
                        android:hint="exemple@email.com"
                        android:textColorHint="#9E9E9E"
                        android:textColor="#000000"
                        android:background="@android:color/transparent"
                        android:padding="16dp"
                        android:textSize="16sp"
                        android:inputType="textEmailAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </androidx.cardview.widget.CardView>

                <!-- Input Password -->
                <TextView
                    android:text="🔒 Mot de passe"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#666666"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="#F8F8F8">

                    <EditText
                        android:id="@+id/registerPassword"
                        android:hint="Choisis un mot de passe"
                        android:textColorHint="#9E9E9E"
                        android:textColor="#000000"
                        android:inputType="textPassword"
                        android:background="@android:color/transparent"
                        android:padding="16dp"
                        android:textSize="16sp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Bouton S'inscrire -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="#4CAF50">

            <Button
                android:id="@+id/registerBtn"
                android:text="🎉 S'inscrire"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="?attr/selectableItemBackground"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:textAllCaps="false"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </androidx.cardview.widget.CardView>
        <TextView
            android:id="@+id/goToLogin"
            android:text="Déjà un compte ? Connecte‑toi"
            android:textSize="16sp"
            android:textColor="#843952"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- Info text -->
        <TextView
            android:text="💡 Astuce : Utilise un mot de passe sécurisé !"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>
</ScrollView>